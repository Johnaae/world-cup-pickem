# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/world_cup_pickem?schema=public"

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-random-secret-string"

# The Odds API (automatic admin sync — not exposed to users)
ODDS_PROVIDER=THEODDSAPI
ODDS_API_KEY=
ODDS_API_SPORT_KEY=soccer_fifa_world_cup
ODDS_API_REGION=us
ODDS_API_MARKETS=h2h,spreads,totals,h2h_h1,spreads_h1,totals_h1,correct_score
