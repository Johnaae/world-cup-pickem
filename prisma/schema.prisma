generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}

enum PickOutcome {
  TEAM_A
  DRAW
  TEAM_B
}

enum PickStatus {
  PENDING
  WON
  LOST
  CANCELLED
}

enum TransactionType {
  INITIAL
  RISK
  WIN
  LOSS
  ADMIN_ADJUSTMENT
  REFUND
}

enum MarketType {
  WINNER
  HANDICAP
  TOTAL_GOALS
  FIRST_HALF_WINNER
  FIRST_HALF_HANDICAP
  FIRST_HALF_TOTAL_GOALS
  SECOND_HALF_WINNER
  SECOND_HALF_HANDICAP
  SECOND_HALF_TOTAL_GOALS
  CORRECT_SCORE
  BOTH_TEAMS_TO_SCORE
  TOTAL_CORNERS
  CORNER_HANDICAP
  TOTAL_CARDS
  NEXT_GOAL
  LIVE_GOAL
}

enum OptionSettlement {
  UNSETTLED
  WON
  LOST
}

enum OddsProvider {
  SPORTSGAMEODDS
  THEODDSAPI
  MANUAL
  AI_IMAGE
}

enum OptionStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

model User {
  id           String              @id @default(cuid())
  name         String
  email        String              @unique
  passwordHash String
  role         Role                @default(USER)
  points       Int                 @default(1000)
  locked       Boolean             @default(false)
  createdAt    DateTime            @default(now())
  picks        Pick[]
  transactions PointsTransaction[]
}

model Match {
  id               String      @id @default(cuid())
  teamA            String
  teamB            String
  startTime        DateTime
  status           MatchStatus @default(UPCOMING)
  scoreA           Int?
  scoreB           Int?
  scoreHalfA       Int?
  scoreHalfB       Int?
  multiplierTeamA  Float       @default(1.5)
  multiplierDraw   Float       @default(3.0)
  multiplierTeamB  Float       @default(2.5)
  oddsApiId        String?       @unique
  externalProvider OddsProvider?
  createdAt        DateTime      @default(now())
  picks            Pick[]
  markets          Market[]
  oddsImportAudits OddsImportAudit[]
}

model Market {
  id           String         @id @default(cuid())
  matchId      String
  type         MarketType
  label        String
  provider     OddsProvider   @default(MANUAL)
  bookmaker    String?
  lastSyncedAt DateTime?
  settledAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  match        Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  options      MarketOption[]
  picks        Pick[]

  @@unique([matchId, type])
}

model MarketOption {
  id             String       @id @default(cuid())
  marketId       String
  label          String
  outcomeType    String
  teamName       String?
  pointLine      Float?
  correctScoreA  Int?
  correctScoreB  Int?
  multiplier     Float
  provider       OddsProvider @default(MANUAL)
  bookmaker      String?
  sourceSyncedAt DateTime?
  status            OptionStatus      @default(ACTIVE)
  note              String?
  settlementResult  OptionSettlement  @default(UNSETTLED)
  externalId        String?
  createdAt         DateTime          @default(now())
  updatedAt      DateTime     @updatedAt
  market         Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  picks          Pick[]

  @@unique([marketId, label, pointLine])
}

model Pick {
  id              String              @id @default(cuid())
  userId          String
  matchId         String
  marketId        String?
  marketOptionId  String?
  selectedOutcome PickOutcome?
  pointsRisked    Int
  multiplier      Float
  status          PickStatus          @default(PENDING)
  pointsWon       Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  match           Match               @relation(fields: [matchId], references: [id], onDelete: Cascade)
  market          Market?             @relation(fields: [marketId], references: [id], onDelete: SetNull)
  marketOption    MarketOption?       @relation(fields: [marketOptionId], references: [id], onDelete: SetNull)
  transactions    PointsTransaction[]

  @@unique([userId, marketId])
}

model PointsTransaction {
  id           String          @id @default(cuid())
  userId       String
  pickId       String?
  type         TransactionType
  amount       Int
  balanceAfter Int
  note         String?
  createdAt    DateTime        @default(now())
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pick         Pick?           @relation(fields: [pickId], references: [id], onDelete: SetNull)
}

model AppSettings {
  id             String    @id @default("default")
  startingPoints Int       @default(1000)
  disclaimer     String    @default("Chỉ mang tính giải trí. Không cá cược tiền thật. Không thanh toán. Không có giải thưởng bằng tiền. Điểm không có giá trị quy đổi.")
  inviteCode     String    @default("WORLDCUP2026")
  lastOddsSyncAt DateTime?
  oddsProvider   String?
  updatedAt      DateTime  @updatedAt
}

model OddsImportAudit {
  id        String   @id @default(cuid())
  matchId   String
  mimeType  String
  fileName  String?
  imageData Bytes?
  bookmaker String?
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}
